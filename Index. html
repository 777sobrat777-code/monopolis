<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Мажор 2048</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0a0a14;display:flex;justify-content:center;align-items:center;min-height:100vh;font-family:'Segoe UI',sans-serif;touch-action:none}
#game{position:relative;width:100%;max-width:420px;padding:12px}
#header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
#title{font-size:28px;font-weight:900;color:#f4c430;text-shadow:0 0 20px rgba(244,196,48,0.4);letter-spacing:2px}
#scores{display:flex;gap:8px}
.score-box{background:#1a1a2e;border:1px solid #f4c43033;border-radius:10px;padding:6px 14px;text-align:center}
.score-label{font-size:10px;color:#f4c43099;text-transform:uppercase;letter-spacing:1px}
.score-val{font-size:20px;font-weight:700;color:#f4c430}
#timer-box{text-align:center;margin-bottom:10px}
#timer{font-size:32px;font-weight:900;color:#f4c430;text-shadow:0 0 15px rgba(244,196,48,0.5);letter-spacing:3px}
#board-wrap{position:relative;background:#12122a;border:2px solid #f4c43044;border-radius:14px;padding:8px}
#board{display:grid;grid-template-columns:repeat(5,1fr);grid-template-rows:repeat(5,1fr);gap:6px;aspect-ratio:1}
.tile{background:#1a1a38;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;transition:all 0.12s ease;position:relative;color:#ccc;border:1px solid #2a2a4a}
.tile.l2{background:#1e3a1e;border-color:#2d5a2d;color:#7f8}
.tile.l3{background:#1e3028;border-color:#2d4a3a;color:#8fa}
.tile.l4{background:#282820;border-color:#4a4a20;color:#dd8}
.tile.l5{background:#2a2018;border-color:#5a3a20;color:#ea8}
.tile.l6{background:#2a1818;border-color:#5a2a2a;color:#f88}
.tile.l7{background:#201830;border-color:#3a2a5a;color:#c8f}
.tile.l8{background:#182030;border-color:#2a3a5a;color:#8cf}
.tile.l9{background:#281a28;border-color:#4a2a4a;color:#f8c}
.tile.l10{background:#1a1a2a;border-color:#f4c430;color:#f4c430;box-shadow:0 0 12px rgba(244,196,48,0.3)}
.tile.l11{background:#1a1a2a;border-color:#f4c430;color:#f4c430;box-shadow:0 0 16px rgba(244,196,48,0.4);font-size:12px}
.tile.l12{background:#1a1a2a;border-color:#f4c430;color:#f4c430;box-shadow:0 0 20px rgba(244,196,48,0.5);font-size:11px}
.tile.l13{background:#1a1a2a;border-color:#ffd700;color:#ffd700;box-shadow:0 0 24px rgba(255,215,0,0.6);font-size:10px}
.tile.l14{background:#1a1a2a;border-color:#ffd700;color:#ffd700;box-shadow:0 0 28px rgba(255,215,0,0.7);font-size:9px}
.tile.l15{background:#1a1a2a;border-color:#ffd700;color:#ffd700;box-shadow:0 0 32px rgba(255,215,0,0.8);font-size:8px}
#overlay{display:none;position:absolute;inset:0;background:rgba(0,0,0,0.75);border-radius:14px;flex-direction:column;align-items:center;justify-content:center;z-index:10}
#overlay.show{display:flex}
#overlay-msg{color:#f4c430;font-size:22px;font-weight:900;text-align:center;text-shadow:0 0 20px rgba(244,196,48,0.5);margin-bottom:6px}
#overlay-sub{color:#f4c43099;font-size:14px;text-align:center;margin-bottom:14px}
#overlay button{background:linear-gradient(135deg,#f4c430,#d4a420);color:#0a0a14;border:none;padding:10px 28px;border-radius:20px;font-size:16px;font-weight:700;cursor:pointer}
#overlay button:active{transform:scale(0.95)}
#music-btn{position:absolute;top:10px;right:10px;width:36px;height:36px;border-radius:50%;background:#1a1a2e;border:1px solid #f4c43044;color:#f4c430;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:5}
#music-btn:active{background:#2a2a3e}
</style>
</head>
<body>
<div id="game">
  <div id="header">
    <div id="title">МАЖОР</div>
    <div id="scores">
      <div class="score-box"><div class="score-label">Счёт</div><div class="score-val" id="score">0</div></div>
      <div class="score-box"><div class="score-label">Лучший</div><div class="score-val" id="best">0</div></div>
    </div>
  </div>
  <div id="timer-box"><div id="timer">00:00</div></div>
  <div id="board-wrap">
    <div id="board"></div>
    <button id="music-btn" title="Музыка">♪</button>
    <div id="overlay"><div id="overlay-msg"></div><div id="overlay-sub"></div><button onclick="restart()">Играть снова</button></div>
  </div>
</div>
<script>
const SIZE=5;
const LEVELS=[
  {v:2,n:'10 ₽',cls:'l2'},{v:4,n:'50 ₽',cls:'l3'},{v:8,n:'100 ₽',cls:'l4'},
  {v:16,n:'200 ₽',cls:'l5'},{v:32,n:'500 ₽',cls:'l6'},{v:64,n:'1000 ₽',cls:'l7'},
  {v:128,n:'2000 ₽',cls:'l8'},{v:256,n:'5000 ₽',cls:'l9'},{v:512,n:'10 000 ₽',cls:'l10'},
  {v:1024,n:'💰 Чемодан',cls:'l11'},{v:2048,n:'🥇 Слиток',cls:'l12'},
  {v:4096,n:'🏎️ Тачка',cls:'l13'},{v:8192,n:'🏦 Банк',cls:'l14'},
  {v:16384,n:'👑 Магнат',cls:'l15'}
];
const lmap={};LEVELS.forEach(l=>lmap[l.v]=l);

let board=[],score=0,best=0,moved=false,timerSec=0,timerInt=null,gameOver=false;

const boardEl=document.getElementById('board'),scoreEl=document.getElementById('score');
const bestEl=document.getElementById('best'),timerEl=document.getElementById('timer');
const overlay=document.getElementById('overlay'),overlayMsg=document.getElementById('overlay-msg');
const overlaySub=document.getElementById('overlay-sub'),musicBtn=document.getElementById('music-btn');

best=parseInt(localStorage.getItem('major2048best')||'0');
bestEl.textContent=best;

// Audio
let audioCtx=null,musicOn=false,musicBuf=null,musicSrc=null,musicGain=null;
function initAudio(){
  if(!audioCtx){audioCtx=new(window.AudioContext||window.webkitAudioContext)();musicGain=audioCtx.createGain();musicGain.gain.value=0.06;musicGain.connect(audioCtx.destination)}
  if(audioCtx.state==='suspended')audioCtx.resume();
  if(!musicBuf)genMusic();
}
function genMusic(){
  const sr=audioCtx.sampleRate,dur=16,len=sr*dur,buf=audioCtx.createBuffer(1,len,sr),d=buf.getChannelData(0);
  const notes=[261.63,293.66,329.63,349.23,392,440,493.88,523.25,587.33,659.25,698.46,783.99];
  const pat=[0,2,4,5,7,9,11,12,11,9,7,5,4,2,0];
  for(let i=0;i<len;i++){
    let t=i/sr,beat=Math.floor(t*2.5)%pat.length,n=notes[pat[beat]],phase=t*n*Math.PI*2;
    let env=Math.exp(-t*0.08)*0.7+0.15;
    d[i]=(Math.sin(phase)+Math.sin(phase*2)*0.3+Math.sin(phase*3)*0.15)*env*0.25;
  }
  musicBuf=buf;
}
function playMusic(){
  if(!audioCtx||audioCtx.state==='suspended')initAudio();
  stopMusic();
  if(!musicBuf)genMusic();
  musicSrc=audioCtx.createBufferSource();musicSrc.buffer=musicBuf;musicSrc.loop=true;
  musicSrc.connect(musicGain);musicSrc.start();musicBtn.textContent='♪';
}
function stopMusic(){if(musicSrc){try{musicSrc.stop()}catch(e){}musicSrc.disconnect();musicSrc=null;musicBtn.textContent='🎵'}}
function toggleMusic(){initAudio();if(musicOn){stopMusic();musicOn=false}else{playMusic();musicOn=true}}

musicBtn.addEventListener('click',toggleMusic);

function init(){
  board=Array.from({length:SIZE},()=>Array(SIZE).fill(0));
  score=0;moved=false;timerSec=0;gameOver=false;
  if(timerInt)clearInterval(timerInt);timerInt=null;
  timerEl.textContent='00:00';scoreEl.textContent='0';
  overlay.classList.remove('show');addTile();addTile();render();
}
function addTile(){
  let empty=[];for(let r=0;r<SIZE;r++)for(let c=0;c<SIZE;c++)if(board[r][c]===0)empty.push({r,c});
  if(empty.length===0)return;
  let pos=empty[Math.floor(Math.random()*empty.length)];
  board[pos.r][pos.c]=Math.random()<0.85?2:4;
}
function render(){
  boardEl.innerHTML='';
  for(let r=0;r<SIZE;r++)for(let c=0;c<SIZE;c++){
    let tile=document.createElement('div');tile.className='tile';
    let v=board[r][c];if(v&&lmap[v]){tile.classList.add(lmap[v].cls);tile.textContent=lmap[v].n}
    boardEl.appendChild(tile);
  }
}
function startTimer(){if(!timerInt){timerInt=setInterval(()=>{timerSec++;let m=Math.floor(timerSec/60),s=timerSec%60;timerEl.textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0')},1000)}}
function slide(row){
  let arr=row.filter(v=>v!==0),newRow=[],i=0;
  while(i<arr.length){
    if(i+1<arr.length&&arr[i]===arr[i+1]){
      let merged=arr[i]*2;newRow.push(merged);score+=merged;i+=2;
    }else{newRow.push(arr[i]);i++}
  }
  while(newRow.length<SIZE)newRow.push(0);return newRow;
}
function move(dir){
  if(gameOver)return;
  let old=board.map(r=>[...r]);
  if(dir==='left'){for(let r=0;r<SIZE;r++)board[r]=slide(board[r])}
  else if(dir==='right'){for(let r=0;r<SIZE;r++)board[r]=slide([...board[r]].reverse()).reverse()}
  else if(dir==='up'){for(let c=0;c<SIZE;c++){let col=[];for(let r=0;r<SIZE;r++)col.push(board[r][c]);let s=slide(col);for(let r=0;r<SIZE;r++)board[r][c]=s[r]}}
  else if(dir==='down'){for(let c=0;c<SIZE;c++){let col=[];for(let r=SIZE-1;r>=0;r--)col.push(board[r][c]);let s=slide(col);for(let r=0;r<SIZE;r++)board[SIZE-1-r][c]=s[r]}}
  let changed=false;for(let r=0;r<SIZE;r++)for(let c=0;c<SIZE;c++)if(board[r][c]!==old[r][c])changed=true;
  if(changed){
    addTile();render();scoreEl.textContent=score;
    if(score>best){best=score;localStorage.setItem('major2048best',best);bestEl.textContent=best}
    startTimer();
    if(isGameOver())endGame(false);
  }
}
function isGameOver(){
  for(let r=0;r<SIZE;r++)for(let c=0;c<SIZE;c++){
    if(board[r][c]===0)return false;
    if(c+1<SIZE&&board[r][c]===board[r][c+1])return false;
    if(r+1<SIZE&&board[r][c]===board[r+1][c])return false;
  }
  return true;
}
function endGame(won){
  gameOver=true;if(timerInt){clearInterval(timerInt);timerInt=null}
  let m=Math.floor(timerSec/60),s=timerSec%60,timeStr=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  let hasMagnat=false;for(let r=0;r<SIZE;r++)for(let c=0;c<SIZE;c++)if(board[r][c]>=16384)hasMagnat=true;
  if(won||hasMagnat){overlayMsg.textContent='👑 МАГНАТ!';overlaySub.textContent='Пал за '+timeStr+' с результатом '+score.toLocaleString()+' ₽'}
  else{overlayMsg.textContent='Игра окончена';overlaySub.textContent='Время: '+timeStr+' • Счёт: '+score.toLocaleString()+' ₽'}
  overlay.classList.add('show');if(musicOn)stopMusic();musicOn=false;
}
function restart(){if(timerInt){clearInterval(timerInt);timerInt=null}init();if(musicOn)playMusic()}

let touchStartX=0,touchStartY=0,touchStarted=false;
boardEl.parentElement.addEventListener('touchstart',e=>{if(gameOver)return;touchStartX=e.touches[0].clientX;touchStartY=e.touches[0].clientY;touchStarted=true},{passive:false});
boardEl.parentElement.addEventListener('touchmove',e=>{e.preventDefault()},{passive:false});
boardEl.parentElement.addEventListener('touchend',e=>{
  if(!touchStarted||gameOver)return;touchStarted=false;
  let dx=e.changedTouches[0].clientX-touchStartX,dy=e.changedTouches[0].clientY-touchStartY;
  if(Math.abs(dx)<20&&Math.abs(dy)<20)return;
  if(Math.abs(dx)>Math.abs(dy))move(dx>0?'right':'left');else move(dy>0?'down':'up');
});
document.addEventListener('keydown',e=>{
  if(gameOver)return;
  if(e.key==='ArrowLeft'){e.preventDefault();move('left')}
  else if(e.key==='ArrowRight'){e.preventDefault();move('right')}
  else if(e.key==='ArrowUp'){e.preventDefault();move('up')}
  else if(e.key==='ArrowDown'){e.preventDefault();move('down')}
});
init();
</script>
</body>
</html>
