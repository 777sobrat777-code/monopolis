<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Мажор 2048</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: #1a1a2e;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh; font-family: 'Arial', sans-serif;
            touch-action: none; -webkit-tap-highlight-color: transparent;
        }
        .container {
            background: #16213e;
            border-radius: 20px; padding: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            max-width: 420px; width: 95%;
        }
        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 15px;
        }
        .title {
            font-size: 32px; font-weight: 900; color: #f5c518;
            text-shadow: 0 0 20px rgba(245,197,24,0.5);
        }
        .scores {
            display: flex; gap: 10px;
        }
        .score-box {
            background: #0f3460; border-radius: 10px; padding: 8px 14px;
            text-align: center; min-width: 70px;
        }
        .score-label {
            font-size: 11px; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;
        }
        .score-value {
            font-size: 22px; font-weight: 700; color: #fff;
        }
        .board {
            background: #0f3460; border-radius: 12px; padding: 10px;
            display: grid; grid-template-columns: repeat(5, 1fr);
            gap: 8px; aspect-ratio: 1; margin-bottom: 15px;
        }
        .tile {
            background: #1a1a40; border-radius: 8px;
            display: flex; justify-content: center; align-items: center;
            font-weight: 700; font-size: 16px; color: #fff;
            transition: all 0.15s ease;
            position: relative; overflow: hidden;
            aspect-ratio: 1;
        }
        .tile[data-value="10"] { background: #2d3436; color: #dfe6e9; font-size: 15px; }
        .tile[data-value="50"] { background: #636e72; color: #fff; font-size: 15px; }
        .tile[data-value="100"] { background: #6c5ce7; color: #fff; font-size: 14px; }
        .tile[data-value="200"] { background: #a29bfe; color: #2d3436; font-size: 14px; }
        .tile[data-value="500"] { background: #00b894; color: #fff; font-size: 14px; }
        .tile[data-value="1000"] { background: #00cec9; color: #2d3436; font-size: 13px; }
        .tile[data-value="2000"] { background: #0984e3; color: #fff; font-size: 13px; }
        .tile[data-value="5000"] { background: #6c5ce7; color: #fff; font-size: 12px; }
        .tile[data-value="10000"] { background: #e17055; color: #fff; font-size: 11px; }
        .tile[data-value="50000"] { background: #d63031; color: #fff; font-size: 11px; }
        .tile[data-value="100000"] { background: #e84393; color: #fff; font-size: 10px; }
        .tile[data-value="500000"] { background: #fd79a8; color: #2d3436; font-size: 10px; }
        .tile[data-value="1000000"] { background: #fdcb6e; color: #2d3436; font-size: 9px; }
        .tile[data-value="10000000"] { background: #f39c12; color: #fff; font-size: 9px; }
        .tile[data-value="100000000"] { background: #e74c3c; color: #ffd700; font-size: 8px; text-shadow: 0 0 10px rgba(255,215,0,0.8); }
        .new-tile { animation: pop 0.2s ease; }
        .merged-tile { animation: merge 0.2s ease; }
        @keyframes pop { 0% { transform: scale(0); } 80% { transform: scale(1.1); } 100% { transform: scale(1); } }
        @keyframes merge { 0% { transform: scale(1); } 50% { transform: scale(1.25); } 100% { transform: scale(1); } }
        .btn {
            display: block; width: 100%; padding: 14px;
            background: #f5c518; color: #1a1a2e; border: none;
            border-radius: 12px; font-size: 18px; font-weight: 700;
            cursor: pointer; letter-spacing: 1px;
            transition: all 0.2s;
        }
        .btn:active { background: #d4a017; transform: scale(0.97); }
        .music-btn {
            position: fixed; top: 15px; right: 15px;
            width: 44px; height: 44px; border-radius: 50%;
            background: #f5c518; border: none; font-size: 22px;
            cursor: pointer; display: flex; justify-content: center;
            align-items: center; z-index: 100; color: #1a1a2e;
            box-shadow: 0 4px 15px rgba(245,197,24,0.4);
        }
        .money { font-size: 10px; opacity: 0.7; margin-left: 1px; }
    </style>
</head>
<body>

<button id="musicToggle" class="music-btn">♪</button>

<div class="container">
    <div class="header">
        <div class="title">МАЖОР</div>
        <div class="scores">
            <div class="score-box">
                <div class="score-label">Игрок</div>
                <div class="score-value" id="score">0</div>
            </div>
            <div class="score-box">
                <div class="score-label">Жулик</div>
                <div class="score-value" id="best">0</div>
            </div>
        </div>
    </div>
    <div class="board" id="board"></div>
    <button class="btn" id="newGame">НОВАЯ ИГРА</button>
</div>

<script>
// --- Audio setup ---
let audioCtx = null;
let musicOn = false;

function initAudio() {
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
}

function playNote(freq, dur, type, vol) {
    if (!audioCtx) return;
    const osc = audioCtx.createOscillator();
    const gain = audioCtx.createGain();
    osc.type = type || 'sine';
    osc.frequency.value = freq;
    gain.gain.setValueAtTime(vol || 0.15, audioCtx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur);
    osc.connect(gain); gain.connect(audioCtx.destination);
    osc.start(audioCtx.currentTime); osc.stop(audioCtx.currentTime + dur);
}

function playMergeSound() { playNote(523, 0.15, 'sine', 0.2); playNote(659, 0.15, 'sine', 0.2); playNote(784, 0.2, 'sine', 0.2); }
function playMoveSound() { playNote(330, 0.08, 'triangle', 0.1); }
function playGameOverSound() { playNote(200, 0.3, 'sawtooth', 0.15); playNote(150, 0.5, 'sawtooth', 0.15); }

let melodyInterval = null;
function startMusic() {
    if (!audioCtx) initAudio();
    if (melodyInterval) return;
    const notes = [262, 294, 330, 349, 392, 349, 330, 294, 262, 330, 392, 440, 392, 330, 294, 262];
    let idx = 0;
    melodyInterval = setInterval(() => {
        playNote(notes[idx % notes.length], 0.25, 'sine', 0.06);
        idx++;
    }, 400);
}

function stopMusic() {
    if (melodyInterval) { clearInterval(melodyInterval); melodyInterval = null; }
}

document.getElementById('musicToggle').addEventListener('click', function() {
    initAudio();
    if (musicOn) {
        stopMusic();
        this.textContent = '♪';
        musicOn = false;
    } else {
        startMusic();
        this.textContent = '♫';
        musicOn = true;
    }
});

// --- Game logic ---
const SIZE = 5;
const LEVELS = [
    { value: 10, label: '10₽', emoji: '💵' },
    { value: 50, label: '50₽', emoji: '💵' },
    { value: 100, label: '100₽', emoji: '💵' },
    { value: 200, label: '200₽', emoji: '💵' },
    { value: 500, label: '500₽', emoji: '💵' },
    { value: 1000, label: '1000₽', emoji: '💴' },
    { value: 2000, label: '2000₽', emoji: '💴' },
    { value: 5000, label: '5000₽', emoji: '💴' },
    { value: 10000, label: '💼10к', emoji: '' },
    { value: 50000, label: '🥇50к', emoji: '' },
    { value: 100000, label: '🚗100к', emoji: '' },
    { value: 500000, label: '🏦500к', emoji: '' },
    { value: 1000000, label: '💰1М', emoji: '' },
    { value: 10000000, label: '👑10М', emoji: '' },
    { value: 100000000, label: '💎МАГНАТ', emoji: '' }
];

let board = [];
let score = 0;
let best = parseInt(localStorage.getItem('majorBest') || '0');

function getLabel(val) {
    const lvl = LEVELS.find(l => l.value === val);
    return lvl ? lvl.label : val + '₽';
}

function init() {
    board = Array(SIZE).fill().map(() => Array(SIZE).fill(0));
    score = 0;
    addRandom(); addRandom();
    updateBest();
    render();
}

function addRandom() {
    const empty = [];
    for (let r = 0; r < SIZE; r++)
        for (let c = 0; c < SIZE; c++)
            if (board[r][c] === 0) empty.push([r, c]);
    if (empty.length === 0) return;
    const [r, c] = empty[Math.floor(Math.random() * empty.length)];
    board[r][c] = Math.random() < 0.7 ? 10 : 50;
}

function updateBest() {
    if (score > best) { best = score; localStorage.setItem('majorBest', best); }
    document.getElementById('best').textContent = best;
    document.getElementById('score').textContent = score;
}

function slide(row) {
    let arr = row.filter(v => v !== 0);
    for (let i = 0; i < arr.length - 1; i++) {
        if (arr[i] === arr[i + 1]) {
            arr[i] *= 2;
            score += arr[i];
            arr.splice(i + 1, 1);
        }
    }
    while (arr.length < SIZE) arr.push(0);
    return arr;
}

function move(direction) {
    let moved = false;
    const old = board.map(r => [...r]);
    const rotatedBoard = [];

    // Rotate board so we always process left-to-right
    if (direction === 'left') {
        for (let r = 0; r < SIZE; r++) {
            const newRow = slide(board[r]);
            if (newRow.join(',') !== board[r].join(',')) moved = true;
            board[r] = newRow;
        }
    } else if (direction === 'right') {
        for (let r = 0; r < SIZE; r++) {
            const rev = [...board[r]].reverse();
            const newRow = slide(rev).reverse();
            if (newRow.join(',') !== board[r].join(',')) moved = true;
            board[r] = newRow;
        }
    } else if (direction === 'up') {
        for (let c = 0; c < SIZE; c++) {
            const col = [];
            for (let r = 0; r < SIZE; r++) col.push(board[r][c]);
            const newCol = slide(col);
            for (let r = 0; r < SIZE; r++) {
                if (board[r][c] !== newCol[r]) moved = true;
                board[r][c] = newCol[r];
            }
        }
    } else if (direction === 'down') {
        for (let c = 0; c < SIZE; c++) {
            const col = [];
            for (let r = 0; r < SIZE; r++) col.push(board[r][c]);
            const rev = col.reverse();
            const newCol = slide(rev).reverse();
            for (let r = 0; r < SIZE; r++) {
                if (board[r][c] !== newCol[r]) moved = true;
                board[r][c] = newCol[r];
            }
        }
    }

    if (moved) {
        addRandom();
        playMoveSound();
        updateBest();
        render();
        if (isGameOver()) {
            playGameOverSound();
            setTimeout(() => alert('Игра окончена! Счёт: ' + score), 300);
        }
    }
}

function isGameOver() {
    for (let r = 0; r < SIZE; r++)
        for (let c = 0; c < SIZE; c++) {
            if (board[r][c] === 0) return false;
            if (r < SIZE - 1 && board[r][c] === board[r + 1][c]) return false;
            if (c < SIZE - 1 && board[r][c] === board[r][c + 1]) return false;
        }
    return true;
}

function render() {
    const boardEl = document.getElementById('board');
    boardEl.innerHTML = '';
    for (let r = 0; r < SIZE; r++) {
        for (let c = 0; c < SIZE; c++) {
            const val = board[r][c];
            const tile = document.createElement('div');
            tile.className = 'tile';
            if (val > 0) {
                tile.setAttribute('data-value', val);
                tile.textContent = getLabel(val);
            }
            boardEl.appendChild(tile);
        }
    }
}

// --- Touch controls ---
let touchStartX = 0, touchStartY = 0;
const SWIPE_THRESHOLD = 30;

document.getElementById('board').addEventListener('touchstart', function(e) {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    e.preventDefault();
}, { passive: false });

document.getElementById('board').addEventListener('touchend', function(e) {
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    const absDx = Math.abs(dx), absDy = Math.abs(dy);
    if (Math.max(absDx, absDy) < SWIPE_THRESHOLD) return;
    if (absDx > absDy) {
        move(dx > 0 ? 'right' : 'left');
    } else {
        move(dy > 0 ? 'down' : 'up');
    }
});

// --- Keyboard ---
document.addEventListener('keydown', function(e) {
    const map = { ArrowLeft: 'left', ArrowRight: 'right', ArrowUp: 'up', ArrowDown: 'down' };
    if (map[e.key]) { e.preventDefault(); move(map[e.key]); }
});

document.getElementById('newGame').addEventListener('click', function() {
    initAudio();
    init();
});

init();
</script>
</body>
</html>
